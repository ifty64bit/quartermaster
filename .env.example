# Local DB commands (bun run db:*) load .env via dotenv. For the
# Cloudflare Worker runtime, use .dev.vars (local) and
# `bun run cf:secret <NAME>` (prod) — Workers don't read .env.

TURSO_AUTH_TOKEN=""
TURSO_DATABASE_URL=""
DATABASE_URL=""
BETTER_AUTH_URL=""
BETTER_AUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""